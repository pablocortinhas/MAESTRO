{
  "name": "maestro",
  "version": "1.1.3",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "import-squads": "node scripts/import-squads.js",
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win --x64 --publish never",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^26.6.10",
    "electron-builder": "^24.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.maestro.tracker",
    "productName": "Maestro",
    "icon": "imagens/maestro_logo.png",
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js",
      "package.json",
      "imagens/maestro_logo.png"
    ],
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Sports"
    }
  }
}
